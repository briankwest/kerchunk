#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop and disable the service before removal
        if [ -d /run/systemd/system ]; then
            systemctl stop kerchunkd.service >/dev/null 2>&1 || true
            systemctl disable kerchunkd.service >/dev/null 2>&1 || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
