mostlyclean-libtool:
	-rm -f *.lo

clean-libtool:
	-rm -rf .libs _libs
	-rm -rf cli/.libs cli/_libs
	-rm -rf modules/.libs modules/_libs
	-rm -rf vendor/.libs vendor/_libs

distclean-libtool:
	-rm -f libtool config.lt
install-docDATA: $(doc_DATA)
	@$(NORMAL_INSTALL)
	@list='$(doc_DATA)'; test -n "$(docdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(docdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(docdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(docdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(docdir)" || exit $$?; \
	done

uninstall-docDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(doc_DATA)'; test -n "$(docdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(docdir)'; $(am__uninstall_files_from_dir)
install-kerchunkconfDATA: $(kerchunkconf_DATA)
	@$(NORMAL_INSTALL)
	@list='$(kerchunkconf_DATA)'; test -n "$(kerchunkconfdir)" || list=; \
	if test -n "$$list"; then \
	  echo " $(MKDIR_P) '$(DESTDIR)$(kerchunkconfdir)'"; \
	  $(MKDIR_P) "$(DESTDIR)$(kerchunkconfdir)" || exit 1; \
	fi; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(kerchunkconfdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(kerchunkconfdir)" || exit $$?; \
	done

uninstall-kerchunkconfDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(kerchunkconf_DATA)'; test -n "$(kerchunkconfdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	dir='$(DESTDIR)$(kerchunkconfdir)'; $(am__uninstall_files_from_dir)
