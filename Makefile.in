	-rm -f modules/$(DEPDIR)/mod_dtmfcmd_la-mod_dtmfcmd.Plo
	-rm -f modules/$(DEPDIR)/mod_emergency_la-mod_emergency.Plo
	-rm -f modules/$(DEPDIR)/mod_freeswitch_la-mod_freeswitch.Plo
	-rm -f modules/$(DEPDIR)/mod_gpio_la-mod_gpio.Plo
	-rm -f modules/$(DEPDIR)/mod_logger_la-mod_logger.Plo
