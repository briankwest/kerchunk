	-$(am__rm_f) cli/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) cli/$(am__dirstamp)
	-$(am__rm_f) modules/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) modules/$(am__dirstamp)
	-$(am__rm_f) src/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) src/$(am__dirstamp)
	-$(am__rm_f) tests/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) tests/$(am__dirstamp)
	-$(am__rm_f) vendor/$(DEPDIR)/$(am__dirstamp)
	-$(am__rm_f) vendor/$(am__dirstamp)

maintainer-clean-generic:
