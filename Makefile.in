ACLOCAL_AMFLAGS = -I m4

# ---------- common flags ----------
AM_CFLAGS = -Wall -Wextra -Wpedantic -O2 \
	    -Iinclude $(PLATFORM_CFLAGS) \
	    $(PLCODE_CFLAGS)


# ---------- convenience library: linenoise ----------
# Vendored linenoise needs relaxed warnings (no -Wpedantic)
noinst_LTLIBRARIES = liblinenoise.la
liblinenoise_la_SOURCES = cli/linenoise.c
liblinenoise_la_CFLAGS = -std=c11 -Wall -O2 \
			   $(PLATFORM_CFLAGS) -D_DEFAULT_SOURCE


# --- kerchunkd (daemon) ---
kerchunkd_SOURCES = \
	src/main.c \
	src/kerchunk_core.c \
	src/kerchunk_events.c \
	src/kerchunk_modules.c \
	src/kerchunk_queue.c \
	src/kerchunk_audio.c \
	src/kerchunk_hid.c \
	src/kerchunk_socket.c \
	src/kerchunk_config.c \
	src/kerchunk_log.c \
	src/kerchunk_user.c \
	src/kerchunk_wav.c \
	src/kerchunk_timer.c \
	src/kerchunk_resp.c \
	src/kerchunk_evt_json.c \
	src/kerchunk_console.c

kerchunkd_CFLAGS = $(AM_CFLAGS) \
		   -Icli \
		   -DKERCHUNK_MODULE_DIR=\"$(kerchunkmoddir)\" \
		   $(PORTAUDIO_CFLAGS) \
		   $(ALSA_CFLAGS)

kerchunkd_LDFLAGS = $(EXPORT_DYNAMIC)
kerchunkd_LDADD = liblinenoise.la \
		  $(PLCODE_LIBS) $(PORTAUDIO_LIBS) $(ALSA_LIBS) \
		  -lm -ldl $(PTHREAD_LIBS)


# --- kerchunk (CLI client) ---
kerchunk_SOURCES = cli/kerchunk.c
kerchunk_CFLAGS = -std=c11 -Wall -O2 \
		  $(PLATFORM_CFLAGS) -D_DEFAULT_SOURCE

kerchunk_LDADD = liblinenoise.la $(PTHREAD_LIBS)

# ---------- modules (libtool modules) ----------
kerchunkmod_LTLIBRARIES = modules/mod_repeater.la modules/mod_cwid.la \
	modules/mod_courtesy.la modules/mod_caller.la \
	modules/mod_dtmfcmd.la modules/mod_voicemail.la \
	modules/mod_gpio.la modules/mod_logger.la \
	modules/mod_weather.la modules/mod_time.la \
	modules/mod_recorder.la modules/mod_txcode.la \
	modules/mod_emergency.la modules/mod_parrot.la \
	modules/mod_cdr.la modules/mod_tts.la modules/mod_nws.la \
	modules/mod_stats.la modules/mod_web.la modules/mod_otp.la \
	modules/mod_webhook.la modules/mod_scrambler.la \
	modules/mod_freeswitch.la $(am__append_1)

